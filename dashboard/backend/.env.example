# Discord Application Credentials
# Obtain at: https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here
# IMPORTANT: Must point to localhost:3000 (frontend proxy), NOT localhost:8000 directly.
# This ensures the auth cookie is set on the same origin the browser uses.
DISCORD_REDIRECT_URI=http://localhost:3000/api/v1/auth/callback

# Security & JWT Token Setup
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET_KEY=your_secure_jwt_secret_key_here

# Bot Management
ADMIN_DISCORD_ID=your_discord_user_id_here

# Frontend Server URL (for CORS and redirects)
FRONTEND_URL=http://localhost:3000

# SQLite Database File Path (Optional, defaults to sqlite:///./dashboard.db)
DATABASE_URL=sqlite:///./dashboard.db
